# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/tickets

# JWT（生产环境务必替换为强随机串）
JWT_SECRET=please-change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# 初始管理员（首次 seed 时创建）
ADMIN_EMAIL=admin@tickets.local
ADMIN_PASSWORD=Admin@12345

# 站点
NEXT_PUBLIC_SITE_NAME=TicketHub

# CSP img-src 白名单（生产环境，逗号分隔的 origin 列表）
# 例：https://cdn.example.com,https://*.amazonaws.com
# 不设置时使用默认：'self' data: https:（覆盖大多数 https 图片 CDN）
# 部署到生产环境建议显式设置白名单以收紧 CSP
CSP_IMG_HOSTS=
